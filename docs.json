{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "FORGE",
  "colors": {
    "primary": "#D9480F",
    "light": "#FF922B",
    "dark": "#9A3412"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "concepts/installation"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/content-model",
              "concepts/fork-model"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/add-an-item",
              "guides/add-an-effect",
              "guides/add-a-recipe"
            ]
          }
        ]
      },
      {
        "tab": "Packages",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "packages/overview"
            ]
          },
          {
            "group": "Foundation",
            "pages": [
              "packages/forge-core",
              "packages/forge-ui",
              "packages/forge-devtools",
              "packages/forge-tests"
            ]
          },
          {
            "group": "Character",
            "pages": [
              "packages/forge-characters",
              "packages/forge-attributes",
              "packages/forge-progression",
              "packages/forge-effects"
            ]
          },
          {
            "group": "Items & world",
            "pages": [
              "packages/forge-items",
              "packages/forge-inventory",
              "packages/forge-equipment",
              "packages/forge-loot",
              "packages/forge-crafting",
              "packages/forge-economy",
              "packages/forge-interactions",
              "packages/forge-instancing"
            ]
          },
          {
            "group": "Gameplay",
            "pages": [
              "packages/forge-combat",
              "packages/forge-abilities",
              "packages/forge-quests",
              "packages/forge-factions",
              "packages/forge-admin"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Framework repo",
          "href": "https://github.com/1kaliel/FORGE-FRAMEWORK",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-nav.png",
    "dark": "/logo/logo-nav.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Framework on GitHub",
      "href": "https://github.com/1kaliel/FORGE-FRAMEWORK"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/1kaliel/FORGE-FRAMEWORK"
    }
  }
