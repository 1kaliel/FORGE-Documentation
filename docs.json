{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FORGE",
  "colors": {
    "primary": "#D9480F",
    "light": "#FF922B",
    "dark": "#9A3412"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "concepts/installation"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/content-model",
              "concepts/fork-model"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/add-an-item",
              "guides/add-an-effect",
              "guides/add-a-recipe"
            ]
          }
        ]
      },
      {
        "tab": "Packages",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "packages/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Framework repo",
          "href": "https://github.com/1kaliel/FORGE-FRAMEWORK",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
